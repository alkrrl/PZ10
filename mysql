import mysql.connector


def get_conn(user, pwd):
    try:
        return mysql.connector.connect(host='localhost', user=user, password=pwd, database='pz10')
    except Exception as e:
        print(f"Ошибка подключения {user}: {e}")
        return None


def run_query(conn, sql, desc):
    if not conn: return
    try:
        cur = conn.cursor(dictionary=True)
        cur.execute(sql)
        if sql.strip().upper().startswith('SELECT'):
            res = cur.fetchall()
            print(f"  {desc}: OK ({len(res)} записей)")
        else:
            conn.commit()
            print(f"  {desc}: OK")
        cur.close()
    except Exception as e:
        print(f"  {desc}: Ошибка - {e}")


